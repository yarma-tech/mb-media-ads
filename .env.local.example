# Copie ce fichier en `.env.local` puis remplis la clé anon.
# Project Settings > API dans le dashboard Supabase du projet xxfqvbvyasnnvmycpogx.
# Si ces variables sont absentes, l'app utilise le catalogue local de secours (lib/catalog-seed.ts).

NEXT_PUBLIC_SUPABASE_URL=https://xxfqvbvyasnnvmycpogx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role (serveur uniquement, JAMAIS exposée au client) — pour la vue admin et la lecture des demandes.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (paiement self-service) — clés de TEST uniquement (dashboard.stripe.com, mode Test).
# Tant qu'elles sont absentes, le bouton « Payer » affiche un message et propose l'expert.
STRIPE_SECRET_KEY=
# Secret de signature du webhook. En local : `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# affiche un `whsec_…` à coller ici.
STRIPE_WEBHOOK_SECRET=
# Optionnel : base URL pour les success/cancel URLs si l'origine de la requête n'est pas fiable.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
