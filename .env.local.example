# Copie ce fichier en `.env.local` puis remplis la clé anon.
# Project Settings > API dans le dashboard Supabase du projet xxfqvbvyasnnvmycpogx.
# Si ces variables sont absentes, l'app utilise le catalogue local de secours (lib/catalog-seed.ts).

NEXT_PUBLIC_SUPABASE_URL=https://xxfqvbvyasnnvmycpogx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role (serveur uniquement, JAMAIS exposée au client) — pour la vue admin et la lecture des demandes.
SUPABASE_SERVICE_ROLE_KEY=
